# Turso database (required)
DATABASE_URL=libsql://your-db-name.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# Render sets PORT automatically — only needed locally
PORT=4000

# Your Vercel frontend URL (comma-separated for multiple origins)
# Used for CORS and QR/join links
FRONTEND_URL=https://your-app.vercel.app

# Required in production — generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string

# MSG91 OTP (customer auth — SMS)
MSG91_AUTH_KEY=your_auth_key_here
MSG91_OTP_TEMPLATE_ID=your_template_id_here
MSG91_SENDER_ID=YOUR_SENDER_ID
MSG91_ROUTE=4
MSG91_OTP_EXPIRY=10
MSG91_OTP_LENGTH=6
# sms = SMS template with ##var1## (your LoyalGenie-OTP template)
# widget = MSG91 OTP widget with ##OTP## only
MSG91_API_MODE=sms

# MSG91 Email OTP (business auth)
MSG91_EMAIL_OTP_TEMPLATE_ID=loyalgenie_otp
MSG91_EMAIL_DOMAIN=9edkvg.mailer91.com
MSG91_EMAIL_FROM=loyalgenie@9edkvg.mailer91.com
MSG91_EMAIL_FROM_NAME=LoyalGenie
MSG91_COMPANY_NAME=LoyalGenie

# Set to true for local dev — uses fixed OTP 123456 instead of SMS/email
MSG91_DEV_OTP=false

# Set automatically on Render
NODE_ENV=production
