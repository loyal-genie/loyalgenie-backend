# Supabase Postgres (required) — Session pooler, port 5432
# If password contains @ encode it as %40 (e.g. pass@word → pass%40word)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Supabase API (required for Realtime in Phase 4; service role for backend)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Cloudflare R2 (required for images — Phase 2)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=loyalgenie-assets
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Render sets PORT automatically — only needed locally
PORT=4000

# Comma-separated, no spaces. First URL is used for QR/join links.
# FRONTEND_URL=https://www.loyalgenie.in,https://loyalgenie.in,https://loyalgenie-frontend.vercel.app,https://loyalgenieapp.vercel.app
FRONTEND_URL=https://www.loyalgenie.in

# Required in production — generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string

# MSG91 OTP (customer auth — SMS)
MSG91_AUTH_KEY=your_auth_key_here
MSG91_OTP_TEMPLATE_ID=your_template_id_here
MSG91_SENDER_ID=YOUR_SENDER_ID
MSG91_ROUTE=4
MSG91_OTP_EXPIRY=10
MSG91_OTP_LENGTH=6
# sms = SMS template with ##var1## (your LoyalGenie-OTP template)
# widget = MSG91 OTP widget with ##OTP## only
MSG91_API_MODE=sms

# MSG91 Email OTP (business auth)
MSG91_EMAIL_OTP_TEMPLATE_ID=loyalgenie_otp
MSG91_EMAIL_DOMAIN=9edkvg.mailer91.com
MSG91_EMAIL_FROM=loyalgenie@9edkvg.mailer91.com
MSG91_EMAIL_FROM_NAME=LoyalGenie
MSG91_COMPANY_NAME=LoyalGenie

# Set to true for local/UAT — fixed OTP 123456 for customer (SMS) and vendor (email).
# Works even when NODE_ENV=production; keep false on Render.
MSG91_DEV_OTP=false

# Set automatically on Render
NODE_ENV=production
