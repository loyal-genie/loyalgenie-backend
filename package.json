{
  "name": "loyalgenie-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c 'if command -v tsx >/dev/null 2>&1; then exec tsx watch src/index.ts; else exec node dist/index.js; fi'",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed-profiles": "tsx scripts/seed-business-profiles.ts",
    "test:shake": "tsx scripts/test-shake-win.ts",
    "test:stamp": "tsx scripts/test-stamp-cards.ts",
    "test:stamp:e2e": "tsx scripts/test-stamp-e2e-prod.ts",
    "test:stamp:frontend": "tsx scripts/test-stamp-frontend-flow.ts",
    "test:stamp:manual": "bash scripts/test-stamp-manual-user.sh",
    "sim:stamp:10d": "tsx scripts/sim-stamp-10-days.ts",
    "test:shake:e2e": "tsx scripts/test-shake-e2e-10-users.ts",
    "test:loyalty:e2e": "tsx scripts/test-check-in-loyalty-e2e.ts",
    "test:pin:boundary": "tsx scripts/test-pin-boundary.ts",
    "test:customer:live": "tsx scripts/test-customer-live-e2e.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.0",
    "qrcode": "^1.5.4",
    "typescript": "^5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
