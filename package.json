    "prestart": "npm run build",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:apply-schema": "tsx scripts/apply-schema.ts",
    "db:enable-realtime": "tsx scripts/apply-realtime.ts",
    "db:enable-realtime-extended": "tsx scripts/apply-realtime-extended.ts",
    "db:drop-blobs": "tsx scripts/apply-drop-blobs.ts",
    "db:apply-rewards-module": "tsx scripts/apply-rewards-module.ts",
    "db:apply-campaign-times": "tsx scripts/apply-campaign-times-reward-expiry.ts",
    "db:cleanup": "tsx scripts/cleanup-supabase.ts",
    "r2:cleanup": "tsx scripts/cleanup-r2.ts",
    "r2:configure-cors": "tsx scripts/configure-r2-cors.ts",
    "db:import": "tsx scripts/import-turso-sqlite.ts",
    "verify:infra": "tsx scripts/verify-infra.ts",
    "audit:db": "tsx scripts/audit-prod-readiness.ts",
    "audit:api": "tsx scripts/audit-api-performance.ts",
    "audit:vendor": "tsx scripts/audit-vendor-flows.ts",
    "audit:customer": "tsx scripts/audit-customer-flows.ts",
